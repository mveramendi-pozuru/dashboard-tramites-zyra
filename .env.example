# Plantilla de variables de entorno.
# Copiar este archivo como ".env" y completar con los valores reales.
# El archivo ".env" NUNCA se sube al repo (está en .gitignore).

# --- Base de datos Zyra (MySQL) ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- Seguridad de los endpoints /debug/ ---
# Token para proteger los endpoints de debug. Inventá una cadena larga y
# aleatoria. Los /debug/ solo responderán si se pasa ?token=ESE_VALOR
DEBUG_TOKEN=
